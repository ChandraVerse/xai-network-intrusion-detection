{\n \"nbformat\": 4,\n \"nbformat_minor\": 5,\n \"metadata\": {\n  \"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n  \"language_info\": {\"name\": \"python\", \"version\": \"3.10.0\"}\n },\n \"cells\": [\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-title\",\n   \"metadata\": {},\n   \"source\": [\n    \"# Phase 4 — XAI with SHAP\\n\",\n    \"## XAI-Based Network Intrusion Detection System\\n\",\n    \"\\n\",\n    \"**Author:** Chandra Sekhar Chakraborty  \\n\",\n    \"**Prerequisite:** Run `03_model_training.ipynb` first  \\n\",\n    \"\\n\",\n    \"---\\n\",\n    \"\\n\",\n    \"### Why SHAP?\\n\",\n    \"SHAP (SHapley Additive exPlanations) is the gold standard for post-hoc XAI:\\n\",\n    \"- **Theoretically grounded** — rooted in cooperative game theory (Shapley values)\\n\",\n    \"- **Model-agnostic interface** — one API for RF, XGBoost, and LSTM\\n\",\n    \"- **Consistent** — changing a feature always changes its SHAP value in the same direction\\n\",\n    \"- **Locally faithful** — explains individual predictions (critical for SOC analysts)\\n\",\n    \"\\n\",\n    \"### Notebook Roadmap\\n\",\n    \"1. [Setup & Load Artifacts](#1-setup--load-artifacts)\\n\",\n    \"2. [SHAP — Random Forest (TreeExplainer)](#2-shap--random-forest-treeexplainer)\\n\",\n    \"3. [SHAP — XGBoost (TreeExplainer + Interactions)](#3-shap--xgboost-treeexplainer--interactions)\\n\",\n    \"4. [SHAP — LSTM (DeepExplainer)](#4-shap--lstm-deepexplainer)\\n\",\n    \"5. [Global Summary — Beeswarm Plots](#5-global-summary--beeswarm-plots)\\n\",\n    \"6. [Local Explanation — Waterfall Charts](#6-local-explanation--waterfall-charts)\\n\",\n    \"7. [Dependence Plots — Top Feature Pairs](#7-dependence-plots--top-feature-pairs)\\n\",\n    \"8. [SHAP Decision Plots](#8-shap-decision-plots)\\n\",\n    \"9. [Cross-Model Feature Importance Consensus](#9-cross-model-feature-importance-consensus)\\n\",\n    \"10. [Export SHAP Values for Dashboard](#10-export-shap-values-for-dashboard)\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s1\",\n   \"metadata\": {},\n   \"source\": [\"## 1. Setup & Load Artifacts\"]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-imports\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"import os, json, warnings\\n\",\n    \"warnings.filterwarnings('ignore')\\n\",\n    \"\\n\",\n    \"import numpy as np\\n\",\n    \"import pandas as pd\\n\",\n    \"import matplotlib.pyplot as plt\\n\",\n    \"import matplotlib.gridspec as gridspec\\n\",\n    \"import seaborn as sns\\n\",\n    \"import joblib\\n\",\n    \"import shap\\n\",\n    \"import tensorflow as tf\\n\",\n    \"\\n\",\n    \"# ── Paths ─────────────────────────────────────────────────────\\n\",\n    \"DATA_PROC_DIR = '../data/processed/'\\n\",\n    \"MODELS_DIR    = '../models/'\\n\",\n    \"SHAP_DIR      = '../docs/shap_plots/'\\n\",\n    \"SHAP_DATA_DIR = '../data/shap/'\\n\",\n    \"os.makedirs(SHAP_DIR,      exist_ok=True)\\n\",\n    \"os.makedirs(SHAP_DATA_DIR, exist_ok=True)\\n\",\n    \"\\n\",\n    \"# ── Plot style ─────────────────────────────────────────────────\\n\",\n    \"plt.rcParams.update({\\n\",\n    \"    'figure.facecolor': '#1a1a2e', 'axes.facecolor': '#16213e',\\n\",\n    \"    'axes.edgecolor':   '#0f3460', 'axes.labelcolor': '#e0e0e0',\\n\",\n    \"    'xtick.color':      '#e0e0e0', 'ytick.color':     '#e0e0e0',\\n\",\n    \"    'text.color':       '#e0e0e0', 'grid.color':      '#0f3460',\\n\",\n    \"    'font.family':      'monospace', 'figure.dpi':   130\\n\",\n    \"})\\n\",\n    \"MODEL_COLORS = {'Random Forest': '#00d4ff', 'XGBoost': '#6bcb77', 'LSTM': '#ff6b6b'}\\n\",\n    \"\\n\",\n    \"shap.initjs()   # enable JS widgets in notebook\\n\",\n    \"print(f'✅ SHAP version : {shap.__version__}')\\n\",\n    \"print(f'✅ TF   version : {tf.__version__}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-load-artifacts\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# ── Load preprocessing metadata ────────────────────────────────\\n\",\n    \"with open(os.path.join(DATA_PROC_DIR, 'preprocessing_meta.json')) as f:\\n\",\n    \"    pre_meta = json.load(f)\\n\",\n    \"\\n\",\n    \"FEATURE_COLS = pre_meta['feature_cols']\\n\",\n    \"N_CLASSES    = pre_meta['n_classes']\\n\",\n    \"LABEL_MAP    = pre_meta['label_map']\\n\",\n    \"CLASS_NAMES  = [LABEL_MAP[str(i)] for i in range(N_CLASSES)]\\n\",\n    \"le           = joblib.load(os.path.join(MODELS_DIR, 'label_encoder.pkl'))\\n\",\n    \"\\n\",\n    \"# ── Load test set ───────────────────────────────────────────────\\n\",\n    \"df_test = pd.read_csv(os.path.join(DATA_PROC_DIR, 'test.csv'))\\n\",\n    \"X_test  = df_test[FEATURE_COLS].values\\n\",\n    \"y_test  = df_test['label'].values.astype(int)\\n\",\n    \"X_test_df = pd.DataFrame(X_test, columns=FEATURE_COLS)\\n\",\n    \"\\n\",\n    \"# ── SHAP background / explanation sample ───────────────────────\\n\",\n    \"# Use a stratified sample for speed — SHAP scales O(n_background * n_explain)\\n\",\n    \"N_BACKGROUND = 500    # background for DeepExplainer / KernelExplainer\\n\",\n    \"N_EXPLAIN    = 1000   # samples to explain\\n\",\n    \"\\n\",\n    \"np.random.seed(42)\\n\",\n    \"explain_idx  = np.random.choice(len(X_test), size=min(N_EXPLAIN, len(X_test)), replace=False)\\n\",\n    \"X_explain    = X_test[explain_idx]\\n\",\n    \"y_explain    = y_test[explain_idx]\\n\",\n    \"X_explain_df = pd.DataFrame(X_explain, columns=FEATURE_COLS)\\n\",\n    \"\\n\",\n    \"bg_idx = np.random.choice(len(X_test), size=min(N_BACKGROUND, len(X_test)), replace=False)\\n\",\n    \"X_background = X_test[bg_idx]\\n\",\n    \"\\n\",\n    \"# ── Load trained models ─────────────────────────────────────────\\n\",\n    \"print('Loading trained models...')\\n\",\n    \"rf  = joblib.load(os.path.join(MODELS_DIR, 'random_forest.pkl'))\\n\",\n    \"xgb = joblib.load(os.path.join(MODELS_DIR, 'xgboost_model.pkl'))\\n\",\n    \"lstm_model = tf.keras.models.load_model(os.path.join(MODELS_DIR, 'lstm_model.keras'))\\n\",\n    \"\\n\",\n    \"print(f'✅ RF  loaded  : {rf.n_estimators} trees')\\n\",\n    \"print(f'✅ XGB loaded  : {xgb.n_estimators} trees')\\n\",\n    \"print(f'✅ LSTM loaded : {lstm_model.count_params():,} params')\\n\",\n    \"print(f'\\\\n   Features : {len(FEATURE_COLS)}')\\n\",\n    \"print(f'   Explain  : {len(X_explain)} samples')\\n\",\n    \"print(f'   Classes  : {CLASS_NAMES}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s2\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 2. SHAP — Random Forest (TreeExplainer)\\n\",\n    \"\\n\",\n    \"> `shap.TreeExplainer` computes **exact** Shapley values for tree ensembles in polynomial time.\\n\",\n    \"> No approximation needed — each SHAP value is exact given the tree structure.\\n\",\n    \"> Output shape: `(n_samples, n_features, n_classes)` — one SHAP matrix per class.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-rf-shap\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"print('Computing SHAP values — Random Forest...')\\n\",\n    \"rf_explainer  = shap.TreeExplainer(rf)\\n\",\n    \"rf_shap_vals  = rf_explainer.shap_values(X_explain)  # list of arrays, one per class\\n\",\n    \"\\n\",\n    \"# rf_shap_vals is a list[n_classes] of (n_samples, n_features)\\n\",\n    \"# Stack into (n_samples, n_features, n_classes)\\n\",\n    \"rf_shap_stack = np.stack(rf_shap_vals, axis=-1)  # shape: (N, F, C)\\n\",\n    \"\\n\",\n    \"# Mean absolute SHAP across all classes → global feature importance\\n\",\n    \"rf_global_imp = np.abs(rf_shap_stack).mean(axis=(0, 2))  # shape: (F,)\\n\",\n    \"rf_top_idx    = np.argsort(rf_global_imp)[::-1][:20]\\n\",\n    \"rf_top_feats  = [FEATURE_COLS[i] for i in rf_top_idx]\\n\",\n    \"\\n\",\n    \"print(f'✅ RF SHAP computed   shape: {rf_shap_stack.shape}')\\n\",\n    \"print(f'   Top 5 features:')\\n\",\n    \"for rank, (feat, imp) in enumerate(zip(rf_top_feats[:5],\\n\",\n    \"                                        rf_global_imp[rf_top_idx[:5]]), 1):\\n\",\n    \"    print(f'   {rank}. {feat:<40} mean|SHAP| = {imp:.6f}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s3\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 3. SHAP — XGBoost (TreeExplainer + Interactions)\\n\",\n    \"\\n\",\n    \"> XGBoost supports **SHAP interaction values** — a matrix of shape `(n_samples, n_features, n_features)`\\n\",\n    \"> that captures pairwise feature interactions on top of the main effect.\\n\",\n    \"> Set `COMPUTE_INTERACTIONS = True` to enable (adds ~5× compute time).\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-xgb-shap\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"COMPUTE_INTERACTIONS = False   # set True for SHAP interaction matrix\\n\",\n    \"\\n\",\n    \"print('Computing SHAP values — XGBoost...')\\n\",\n    \"xgb_explainer = shap.TreeExplainer(xgb)\\n\",\n    \"xgb_shap_vals = xgb_explainer.shap_values(X_explain)\\n\",\n    \"\\n\",\n    \"# XGBoost multi-class: list[n_classes] or (n_samples, n_features) for binary\\n\",\n    \"if isinstance(xgb_shap_vals, list):\\n\",\n    \"    xgb_shap_stack = np.stack(xgb_shap_vals, axis=-1)\\n\",\n    \"else:\\n\",\n    \"    xgb_shap_stack = xgb_shap_vals[:, :, np.newaxis]\\n\",\n    \"\\n\",\n    \"xgb_global_imp = np.abs(xgb_shap_stack).mean(axis=(0, 2))\\n\",\n    \"xgb_top_idx    = np.argsort(xgb_global_imp)[::-1][:20]\\n\",\n    \"xgb_top_feats  = [FEATURE_COLS[i] for i in xgb_top_idx]\\n\",\n    \"\\n\",\n    \"print(f'✅ XGB SHAP computed  shape: {xgb_shap_stack.shape}')\\n\",\n    \"print(f'   Top 5 features:')\\n\",\n    \"for rank, (feat, imp) in enumerate(zip(xgb_top_feats[:5],\\n\",\n    \"                                        xgb_global_imp[xgb_top_idx[:5]]), 1):\\n\",\n    \"    print(f'   {rank}. {feat:<40} mean|SHAP| = {imp:.6f}')\\n\",\n    \"\\n\",\n    \"# ── Optional: SHAP interaction values ─────────────────────────\\n\",\n    \"xgb_shap_interact = None\\n\",\n    \"if COMPUTE_INTERACTIONS:\\n\",\n    \"    print('\\\\nComputing SHAP interaction values (may take ~10 min)...')\\n\",\n    \"    xgb_shap_interact = xgb_explainer.shap_interaction_values(X_explain[:200])\\n\",\n    \"    print(f'✅ Interaction matrix shape: {np.array(xgb_shap_interact).shape}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s4\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 4. SHAP — LSTM (DeepExplainer)\\n\",\n    \"\\n\",\n    \"> `shap.DeepExplainer` uses backpropagation to compute SHAP values for neural networks.\\n\",\n    \"> For our LSTM, we create a **flattened wrapper** — DeepExplainer sees a 2D input\\n\",\n    \"> `(batch, time_steps * features)` and we reshape internally.\\n\",\n    \">\\n\",\n    \"> SHAP values are then averaged across the time dimension to get per-feature importance,\\n\",\n    \"> comparable to the RF and XGBoost outputs.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-lstm-shap-prep\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"TIME_STEPS = 5\\n\",\n    \"N_FEATS    = len(FEATURE_COLS)\\n\",\n    \"\\n\",\n    \"def reshape_for_lstm(X, time_steps):\\n\",\n    \"    n = len(X) - (len(X) % time_steps)\\n\",\n    \"    return X[:n].reshape(-1, time_steps, X.shape[1])\\n\",\n    \"\\n\",\n    \"# Prepare sequences for DeepExplainer\\n\",\n    \"X_bg_seq  = reshape_for_lstm(X_background[:N_BACKGROUND], TIME_STEPS)\\n\",\n    \"X_exp_seq = reshape_for_lstm(X_explain[:500], TIME_STEPS)   # limit for speed\\n\",\n    \"y_exp_seq = y_explain[:(len(X_explain[:500]) - len(X_explain[:500]) % TIME_STEPS):TIME_STEPS]\\n\",\n    \"\\n\",\n    \"print(f'LSTM input shapes:')\\n\",\n    \"print(f'  Background : {X_bg_seq.shape}')\\n\",\n    \"print(f'  Explain    : {X_exp_seq.shape}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-lstm-shap\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"print('Computing SHAP values — LSTM (DeepExplainer)...')\\n\",\n    \"print('  This may take 10–20 min depending on hardware.')\\n\",\n    \"\\n\",\n    \"lstm_explainer  = shap.DeepExplainer(lstm_model, X_bg_seq)\\n\",\n    \"lstm_shap_raw   = lstm_explainer.shap_values(X_exp_seq)\\n\",\n    \"# lstm_shap_raw: list[n_classes] of (n_seq, time_steps, n_features)\\n\",\n    \"\\n\",\n    \"# Average over time dimension → (n_seq, n_features, n_classes)\\n\",\n    \"lstm_shap_stack = np.stack([v.mean(axis=1) for v in lstm_shap_raw], axis=-1)\\n\",\n    \"lstm_global_imp = np.abs(lstm_shap_stack).mean(axis=(0, 2))\\n\",\n    \"lstm_top_idx    = np.argsort(lstm_global_imp)[::-1][:20]\\n\",\n    \"lstm_top_feats  = [FEATURE_COLS[i] for i in lstm_top_idx]\\n\",\n    \"\\n\",\n    \"print(f'✅ LSTM SHAP computed  shape: {lstm_shap_stack.shape}')\\n\",\n    \"print(f'   Top 5 features:')\\n\",\n    \"for rank, (feat, imp) in enumerate(zip(lstm_top_feats[:5],\\n\",\n    \"                                        lstm_global_imp[lstm_top_idx[:5]]), 1):\\n\",\n    \"    print(f'   {rank}. {feat:<40} mean|SHAP| = {imp:.6f}')\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s5\",\n   \"metadata\": {},\n   \"source\": [\"## 5. Global Summary — Beeswarm Plots\"]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-beeswarm\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# ── Beeswarm for each model — shows distribution of SHAP values ──\\n\",\n    \"# We pick the BENIGN class (idx 0) vs ALL-ATTACK aggregate\\n\",\n    \"\\n\",\n    \"def plot_beeswarm(shap_stack, X_df, class_idx, class_name, model_name, save_path, top_n=20):\\n\",\n    \"    \\\"\\\"\\\"Plot SHAP beeswarm for one class.\\\"\\\"\\\"\\n\",\n    \"    shap_cls  = shap_stack[:, :, class_idx]   # (N, F)\\n\",\n    \"    top_feat_idx = np.argsort(np.abs(shap_cls).mean(axis=0))[::-1][:top_n]\\n\",\n    \"    top_names = [FEATURE_COLS[i] for i in top_feat_idx]\\n\",\n    \"\\n\",\n    \"    # Build a shap.Explanation object for the built-in beeswarm\\n\",\n    \"    exp = shap.Explanation(\\n\",\n    \"        values      = shap_cls[:, top_feat_idx],\\n\",\n    \"        base_values = np.zeros(len(shap_cls)),\\n\",\n    \"        data        = X_df.values[:len(shap_cls), top_feat_idx],\\n\",\n    \"        feature_names = top_names\\n\",\n    \"    )\\n\",\n    \"    fig, ax = plt.subplots(figsize=(12, 8))\\n\",\n    \"    shap.plots.beeswarm(exp, max_display=top_n, show=False)\\n\",\n    \"    plt.title(f'{model_name} — SHAP Beeswarm ({class_name})',\\n\",\n    \"              fontsize=12, fontweight='bold', color=MODEL_COLORS.get(model_name, '#e0e0e0'),\\n\",\n    \"              pad=14)\\n\",\n    \"    plt.tight_layout()\\n\",\n    \"    plt.savefig(save_path, dpi=150, bbox_inches='tight')\\n\",\n    \"    plt.show()\\n\",\n    \"    print(f'💾 Saved → {save_path}')\\n\",\n    \"\\n\",\n    \"# ── Plot for all 3 models ─────────────────────────────────────\\n\",\n    \"# Use class 0 (BENIGN) — most actionable for SOC analysts (what keeps traffic benign)\\n\",\n    \"benign_id = list(le.classes_).index('BENIGN') if 'BENIGN' in le.classes_ else 0\\n\",\n    \"\\n\",\n    \"plot_beeswarm(rf_shap_stack,   X_explain_df,\\n\",\n    \"              benign_id, 'BENIGN', 'Random Forest',\\n\",\n    \"              os.path.join(SHAP_DIR, '01_rf_beeswarm_benign.png'))\\n\",\n    \"\\n\",\n    \"plot_beeswarm(xgb_shap_stack,  X_explain_df,\\n\",\n    \"              benign_id, 'BENIGN', 'XGBoost',\\n\",\n    \"              os.path.join(SHAP_DIR, '02_xgb_beeswarm_benign.png'))\\n\",\n    \"\\n\",\n    \"plot_beeswarm(lstm_shap_stack, X_explain_df[:len(lstm_shap_stack)],\\n\",\n    \"              benign_id, 'BENIGN', 'LSTM',\\n\",\n    \"              os.path.join(SHAP_DIR, '03_lstm_beeswarm_benign.png'))\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s6\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 6. Local Explanation — Waterfall Charts\\n\",\n    \"\\n\",\n    \"> A waterfall chart explains a **single prediction**:\\n\",\n    \"> starting from the base value (expected model output), each bar shows how much\\n\",\n    \"> each feature pushes the prediction up (red) or down (blue).\\n\",\n    \"> We pick one correctly predicted attack sample and one false positive for comparison.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-waterfall\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def plot_waterfall(shap_stack, X_df, base_vals, sample_idx, class_idx,\\n\",\n    \"                   class_name, model_name, save_path, top_n=15):\\n\",\n    \"    shap_sample = shap_stack[sample_idx, :, class_idx]\\n\",\n    \"    top_feat_idx = np.argsort(np.abs(shap_sample))[::-1][:top_n]\\n\",\n    \"    top_names  = [FEATURE_COLS[i] for i in top_feat_idx]\\n\",\n    \"    top_vals   = shap_sample[top_feat_idx]\\n\",\n    \"    top_data   = X_df.values[sample_idx, top_feat_idx]\\n\",\n    \"\\n\",\n    \"    exp = shap.Explanation(\\n\",\n    \"        values        = top_vals,\\n\",\n    \"        base_values   = float(base_vals[class_idx]) if hasattr(base_vals, '__len__') else float(base_vals),\\n\",\n    \"        data          = top_data,\\n\",\n    \"        feature_names = top_names\\n\",\n    \"    )\\n\",\n    \"    plt.figure(figsize=(12, 6))\\n\",\n    \"    shap.plots.waterfall(exp, max_display=top_n, show=False)\\n\",\n    \"    plt.title(f'{model_name} — Waterfall ({class_name}, sample #{sample_idx})',\\n\",\n    \"              fontsize=11, fontweight='bold', color=MODEL_COLORS.get(model_name,'#e0e0e0'),\\n\",\n    \"              pad=12)\\n\",\n    \"    plt.tight_layout()\\n\",\n    \"    plt.savefig(save_path, dpi=150, bbox_inches='tight')\\n\",\n    \"    plt.show()\\n\",\n    \"    print(f'💾 Saved → {save_path}')\\n\",\n    \"\\n\",\n    \"# Pick an attack sample\\n\",\n    \"attack_mask = y_explain != benign_id\\n\",\n    \"attack_samples = np.where(attack_mask)[0]\\n\",\n    \"sample_atk = attack_samples[0] if len(attack_samples) > 0 else 0\\n\",\n    \"\\n\",\n    \"# RF base values\\n\",\n    \"rf_base = rf_explainer.expected_value    # list[n_classes]\\n\",\n    \"xgb_base = xgb_explainer.expected_value\\n\",\n    \"\\n\",\n    \"# Attack class id of this sample\\n\",\n    \"atk_class_id = int(y_explain[sample_atk])\\n\",\n    \"atk_class_name = CLASS_NAMES[atk_class_id]\\n\",\n    \"\\n\",\n    \"# RF waterfall\\n\",\n    \"plot_waterfall(rf_shap_stack, X_explain_df,\\n\",\n    \"               rf_base, sample_atk, atk_class_id,\\n\",\n    \"               atk_class_name, 'Random Forest',\\n\",\n    \"               os.path.join(SHAP_DIR, '04_rf_waterfall_attack.png'))\\n\",\n    \"\\n\",\n    \"# XGB waterfall\\n\",\n    \"plot_waterfall(xgb_shap_stack, X_explain_df,\\n\",\n    \"               xgb_base, sample_atk, atk_class_id,\\n\",\n    \"               atk_class_name, 'XGBoost',\\n\",\n    \"               os.path.join(SHAP_DIR, '05_xgb_waterfall_attack.png'))\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s7\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 7. Dependence Plots — Top Feature Pairs\\n\",\n    \"\\n\",\n    \"> A dependence plot shows how a single feature's SHAP value changes with its raw value,\\n\",\n    \"> colored by the feature that most interacts with it (auto-selected by SHAP).\\n\",\n    \"> This reveals non-linear relationships and interaction effects invisible in simple importances.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-dependence\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"def plot_dependence_grid(shap_vals_2d, X_arr, feature_names, top_n, model_name, save_path):\\n\",\n    \"    \\\"\\\"\\\"Plot 2×(top_n//2) dependence plots in a grid.\\\"\\\"\\\"\\n\",\n    \"    cols_to_plot = top_n\\n\",\n    \"    ncols = 4\\n\",\n    \"    nrows = (cols_to_plot + ncols - 1) // ncols\\n\",\n    \"\\n\",\n    \"    fig, axes = plt.subplots(nrows, ncols, figsize=(5*ncols, 4*nrows))\\n\",\n    \"    fig.suptitle(f'{model_name} — SHAP Dependence Plots (Top {cols_to_plot} Features)',\\n\",\n    \"                 fontsize=13, fontweight='bold',\\n\",\n    \"                 color=MODEL_COLORS.get(model_name, '#e0e0e0'))\\n\",\n    \"    axes = axes.flatten()\\n\",\n    \"\\n\",\n    \"    global_imp = np.abs(shap_vals_2d).mean(axis=0)\\n\",\n    \"    top_idx    = np.argsort(global_imp)[::-1][:cols_to_plot]\\n\",\n    \"\\n\",\n    \"    for plot_i, feat_i in enumerate(top_idx):\\n\",\n    \"        ax = axes[plot_i]\\n\",\n    \"        feat_name = feature_names[feat_i]\\n\",\n    \"        # Compute interaction feature (most correlated SHAP)\\n\",\n    \"        corrs = [abs(np.corrcoef(shap_vals_2d[:, feat_i],\\n\",\n    \"                                  shap_vals_2d[:, j])[0, 1])\\n\",\n    \"                 for j in range(shap_vals_2d.shape[1]) if j != feat_i]\\n\",\n    \"        interact_feat_i = int(np.argsort(corrs)[::-1][0])\\n\",\n    \"        if interact_feat_i >= feat_i: interact_feat_i += 1\\n\",\n    \"\\n\",\n    \"        sc = ax.scatter(\\n\",\n    \"            X_arr[:, feat_i],\\n\",\n    \"            shap_vals_2d[:, feat_i],\\n\",\n    \"            c=X_arr[:, interact_feat_i],\\n\",\n    \"            cmap='coolwarm', alpha=0.5, s=8\\n\",\n    \"        )\\n\",\n    \"        plt.colorbar(sc, ax=ax, label=feature_names[interact_feat_i][:18], pad=0.01)\\n\",\n    \"        ax.axhline(0, color='#555', lw=0.8, ls='--')\\n\",\n    \"        ax.set_xlabel(feat_name[:22], fontsize=7)\\n\",\n    \"        ax.set_ylabel('SHAP value', fontsize=7)\\n\",\n    \"        ax.set_title(feat_name[:28], fontsize=7, color='#e0e0e0')\\n\",\n    \"        ax.tick_params(labelsize=6)\\n\",\n    \"\\n\",\n    \"    for ax in axes[cols_to_plot:]: ax.set_visible(False)\\n\",\n    \"    plt.tight_layout()\\n\",\n    \"    plt.savefig(save_path, dpi=130, bbox_inches='tight')\\n\",\n    \"    plt.show()\\n\",\n    \"    print(f'💾 Saved → {save_path}')\\n\",\n    \"\\n\",\n    \"# RF dependence — use mean SHAP across all classes (2D)\\n\",\n    \"rf_shap_2d  = rf_shap_stack.mean(axis=2)   # (N, F)\\n\",\n    \"xgb_shap_2d = xgb_shap_stack.mean(axis=2)\\n\",\n    \"\\n\",\n    \"plot_dependence_grid(rf_shap_2d,  X_explain, FEATURE_COLS, 12,\\n\",\n    \"                     'Random Forest',\\n\",\n    \"                     os.path.join(SHAP_DIR, '06_rf_dependence_grid.png'))\\n\",\n    \"\\n\",\n    \"plot_dependence_grid(xgb_shap_2d, X_explain, FEATURE_COLS, 12,\\n\",\n    \"                     'XGBoost',\\n\",\n    \"                     os.path.join(SHAP_DIR, '07_xgb_dependence_grid.png'))\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s8\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 8. SHAP Decision Plots\\n\",\n    \"\\n\",\n    \"> Decision plots trace the cumulative SHAP contribution from the base value to the final prediction\\n\",\n    \"> across all features — ideal for multi-class comparisons and SOC analyst walk-throughs.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-decision\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Decision plot: compare 30 samples across predicted attack class\\n\",\n    \"N_DECISION = 30\\n\",\n    \"\\n\",\n    \"def plot_decision(shap_vals_2d, X_df, base_val, model_name, save_path, n=30):\\n\",\n    \"    top_feat_idx = np.argsort(np.abs(shap_vals_2d).mean(axis=0))[::-1][:20]\\n\",\n    \"    top_names    = [FEATURE_COLS[i] for i in top_feat_idx]\\n\",\n    \"\\n\",\n    \"    plt.figure(figsize=(10, 8))\\n\",\n    \"    shap.decision_plot(\\n\",\n    \"        base_val,\\n\",\n    \"        shap_vals_2d[:n, top_feat_idx],\\n\",\n    \"        feature_names=top_names,\\n\",\n    \"        show=False,\\n\",\n    \"        plot_color=plt.cm.coolwarm\\n\",\n    \"    )\\n\",\n    \"    plt.title(f'{model_name} — SHAP Decision Plot ({n} samples)',\\n\",\n    \"              fontsize=11, fontweight='bold', color=MODEL_COLORS.get(model_name, '#e0e0e0'))\\n\",\n    \"    plt.tight_layout()\\n\",\n    \"    plt.savefig(save_path, dpi=150, bbox_inches='tight')\\n\",\n    \"    plt.show()\\n\",\n    \"    print(f'💾 Saved → {save_path}')\\n\",\n    \"\\n\",\n    \"# RF decision plot (use expected_value for benign class)\\n\",\n    \"rf_base_val = rf_base[benign_id] if isinstance(rf_base, list) else rf_base\\n\",\n    \"plot_decision(rf_shap_2d, X_explain_df,\\n\",\n    \"              rf_base_val, 'Random Forest',\\n\",\n    \"              os.path.join(SHAP_DIR, '08_rf_decision_plot.png'), n=N_DECISION)\\n\",\n    \"\\n\",\n    \"xgb_base_val = xgb_base[benign_id] if isinstance(xgb_base, list) else xgb_base\\n\",\n    \"plot_decision(xgb_shap_2d, X_explain_df,\\n\",\n    \"              xgb_base_val, 'XGBoost',\\n\",\n    \"              os.path.join(SHAP_DIR, '09_xgb_decision_plot.png'), n=N_DECISION)\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s9\",\n   \"metadata\": {},\n   \"source\": [\n    \"## 9. Cross-Model Feature Importance Consensus\\n\",\n    \"\\n\",\n    \"> Rank features by mean |SHAP| across all three models.\\n\",\n    \"> Features that rank in the top 10 for all three models are the most robust —\\n\",\n    \"> these are the **consensus features** that should be monitored in a live SOC.\"\n   ]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-consensus\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# ── Build importance DataFrames for each model ─────────────────\\n\",\n    \"def shap_importance_df(shap_stack, model_name):\\n\",\n    \"    imp = np.abs(shap_stack).mean(axis=(0, 2))\\n\",\n    \"    df  = pd.DataFrame({'feature': FEATURE_COLS, f'imp_{model_name}': imp})\\n\",\n    \"    df  = df.sort_values(f'imp_{model_name}', ascending=False).reset_index(drop=True)\\n\",\n    \"    df[f'rank_{model_name}'] = df.index + 1\\n\",\n    \"    return df\\n\",\n    \"\\n\",\n    \"df_rf  = shap_importance_df(rf_shap_stack,   'RF')\\n\",\n    \"df_xgb = shap_importance_df(xgb_shap_stack,  'XGB')\\n\",\n    \"df_lst = shap_importance_df(lstm_shap_stack, 'LSTM')\\n\",\n    \"\\n\",\n    \"# Merge on feature name\\n\",\n    \"df_consensus = (df_rf[['feature', 'imp_RF', 'rank_RF']]\\n\",\n    \"                .merge(df_xgb[['feature', 'imp_XGB', 'rank_XGB']], on='feature')\\n\",\n    \"                .merge(df_lst[['feature', 'imp_LSTM', 'rank_LSTM']], on='feature'))\\n\",\n    \"\\n\",\n    \"df_consensus['mean_rank'] = df_consensus[['rank_RF', 'rank_XGB', 'rank_LSTM']].mean(axis=1)\\n\",\n    \"df_consensus['mean_imp']  = df_consensus[['imp_RF', 'imp_XGB', 'imp_LSTM']].mean(axis=1)\\n\",\n    \"df_consensus = df_consensus.sort_values('mean_rank').reset_index(drop=True)\\n\",\n    \"\\n\",\n    \"print('TOP 15 CONSENSUS FEATURES (cross-model SHAP agreement):')\\n\",\n    \"print('=' * 85)\\n\",\n    \"print(f'{\\\"Rank\\\":<5} {\\\"Feature\\\":<40} {\\\"RF Rank\\\":>8} {\\\"XGB Rank\\\":>9} {\\\"LSTM Rank\\\":>10} {\\\"Mean Rank\\\":>10}')\\n\",\n    \"print('-' * 85)\\n\",\n    \"for i, row in df_consensus.head(15).iterrows():\\n\",\n    \"    print(f'{i+1:<5} {row.feature:<40} {row.rank_RF:>8.0f} {row.rank_XGB:>9.0f} {row.rank_LSTM:>10.0f} {row.mean_rank:>10.1f}')\\n\",\n    \"\\n\",\n    \"# ── Consensus bar chart ────────────────────────────────────────\\n\",\n    \"TOP_N_PLOT = 20\\n\",\n    \"df_top = df_consensus.head(TOP_N_PLOT)\\n\",\n    \"\\n\",\n    \"fig, ax = plt.subplots(figsize=(14, 7))\\n\",\n    \"x = np.arange(TOP_N_PLOT)\\n\",\n    \"w = 0.25\\n\",\n    \"ax.bar(x - w,   df_top.imp_RF,   w, label='Random Forest', color=MODEL_COLORS['Random Forest'], alpha=0.9)\\n\",\n    \"ax.bar(x,       df_top.imp_XGB,  w, label='XGBoost',       color=MODEL_COLORS['XGBoost'],       alpha=0.9)\\n\",\n    \"ax.bar(x + w,   df_top.imp_LSTM, w, label='LSTM',          color=MODEL_COLORS['LSTM'],          alpha=0.9)\\n\",\n    \"ax.set_xticks(x)\\n\",\n    \"ax.set_xticklabels([f[:22] for f in df_top.feature], rotation=45, ha='right', fontsize=7)\\n\",\n    \"ax.set_ylabel('Mean |SHAP|', fontsize=10)\\n\",\n    \"ax.set_title('Cross-Model SHAP Feature Importance Consensus\\\\n(Top 20 by average rank across RF, XGBoost, LSTM)',\\n\",\n    \"             fontsize=12, fontweight='bold', color='#00d4ff')\\n\",\n    \"ax.legend(fontsize=9)\\n\",\n    \"ax.grid(axis='y', alpha=0.3)\\n\",\n    \"plt.tight_layout()\\n\",\n    \"plt.savefig(os.path.join(SHAP_DIR, '10_consensus_feature_importance.png'), dpi=150, bbox_inches='tight')\\n\",\n    \"plt.show()\\n\",\n    \"print('💾 Saved → docs/shap_plots/10_consensus_feature_importance.png')\"\n   ]\n  },\n  {\n   \"cell_type\": \"markdown\",\n   \"id\": \"cell-s10\",\n   \"metadata\": {},\n   \"source\": [\"## 10. Export SHAP Values for Dashboard\"]\n  },\n  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"cell-export\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"print('EXPORTING SHAP VALUES FOR PHASE 5 DASHBOARD')\\n\",\n    \"print('─' * 55)\\n\",\n    \"\\n\",\n    \"# ── Per-sample SHAP for dashboard (top 20 features only, all models) ──\\n\",\n    \"TOP_EXPORT = 20\\n\",\n    \"consensus_feats = df_consensus.head(TOP_EXPORT)['feature'].tolist()\\n\",\n    \"consensus_idx   = [FEATURE_COLS.index(f) for f in consensus_feats]\\n\",\n    \"\\n\",\n    \"def export_shap(shap_stack, label, model_tag):\\n\",\n    \"    # Mean over classes → (N, F), then keep top features\\n\",\n    \"    shap_2d = shap_stack.mean(axis=2)[:, consensus_idx]\\n\",\n    \"    df = pd.DataFrame(shap_2d, columns=consensus_feats)\\n\",\n    \"    df.insert(0, 'y_true', label[:len(df)])\\n\",\n    \"    path = os.path.join(SHAP_DATA_DIR, f'shap_{model_tag}.csv')\\n\",\n    \"    df.to_csv(path, index=False)\\n\",\n    \"    print(f'  ✅ {path}  ({df.shape[0]} rows × {df.shape[1]} cols)')\\n\",\n    \"    return df\\n\",\n    \"\\n\",\n    \"df_shap_rf  = export_shap(rf_shap_stack,   y_explain,     'rf')\\n\",\n    \"df_shap_xgb = export_shap(xgb_shap_stack,  y_explain,     'xgb')\\n\",\n    \"df_shap_lstm= export_shap(lstm_shap_stack, y_exp_seq,     'lstm')\\n\",\n    \"\\n\",\n    \"# ── Save consensus feature list ────────────────────────────────\\n\",\n    \"consensus_path = os.path.join(SHAP_DATA_DIR, 'consensus_features.json')\\n\",\n    \"with open(consensus_path, 'w') as f:\\n\",\n    \"    json.dump({'top_features': consensus_feats,\\n\",\n    \"               'feature_cols': FEATURE_COLS,\\n\",\n    \"               'n_classes': N_CLASSES,\\n\",\n    \"               'class_names': CLASS_NAMES}, f, indent=2)\\n\",\n    \"print(f'  ✅ {consensus_path}')\\n\",\n    \"\\n\",\n    \"# ── Phase 4 summary ───────────────────────────────────────────\\n\",\n    \"print()\\n\",\n    \"print('=' * 65)\\n\",\n    \"print('PHASE 4 — XAI COMPLETE')\\n\",\n    \"print('=' * 65)\\n\",\n    \"print(f'''\\n\",\n    \"SHAP PLOTS SAVED (docs/shap_plots/):\\n\",\n    \"  01_rf_beeswarm_benign.png\\n\",\n    \"  02_xgb_beeswarm_benign.png\\n\",\n    \"  03_lstm_beeswarm_benign.png\\n\",\n    \"  04_rf_waterfall_attack.png\\n\",\n    \"  05_xgb_waterfall_attack.png\\n\",\n    \"  06_rf_dependence_grid.png\\n\",\n    \"  07_xgb_dependence_grid.png\\n\",\n    \"  08_rf_decision_plot.png\\n\",\n    \"  09_xgb_decision_plot.png\\n\",\n    \"  10_consensus_feature_importance.png\\n\",\n    \"\\n\",\n    \"SHAP DATA EXPORTED (data/shap/):\\n\",\n    \"  shap_rf.csv, shap_xgb.csv, shap_lstm.csv\\n\",\n    \"  consensus_features.json\\n\",\n    \"\\n\",\n    \"NEXT: notebooks/05_dashboard.ipynb\\n\",\n    \"  → Streamlit dashboard with live traffic simulation\\n\",\n    \"  → Real-time SHAP waterfall for each alert\\n\",\n    \"  → Attack timeline, class distribution, top features\\n\",\n    \"  → Model switcher (RF / XGBoost / LSTM)\\n\",\n    \"''')\\n\",\n    \"print('=' * 65)\"\n   ]\n  }\n ]\n}\n
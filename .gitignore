# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
dist/
build/
*.egg

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Raw data only (never commit raw PCAP / full CSVs) ─────
data/raw/
*.pcap
*.pcapng

# NOTE: data/processed/ and data/samples/ are intentionally
# NOT ignored — small compressed artifacts are committed.
# Large raw files belong in data/raw/ which IS ignored.

# ── Model binaries — small trained artifacts ARE committed ─
# (kept under ~2 MB total; trained via GitHub Actions)
# Only exclude huge files you'd never want in git:
*.pt
*.pth
*.onnx
*.ckpt

# ── Secrets & Environment ─────────────────────────────────
.env
.env.local
.env.*
secrets.yaml

# ── IDE / OS ──────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store
Thumbs.db
*.swp
*.swo

# ── Reports (generated, not source) ───────────────────────
docs/eda_plots/*.png
reports/figures/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Streamlit cache ───────────────────────────────────────
.streamlit/
